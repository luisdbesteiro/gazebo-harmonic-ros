<?xml version="1.0"?>
<model>
  <name>Unitree G1 29DoF fixed hip joint position control</name>
  <version>1.0</version>
  <sdf version="1.11">model.sdf</sdf>
  <author>
    <name>Local Gazebo Harmonic ROS 2 workspace</name>
  </author>
