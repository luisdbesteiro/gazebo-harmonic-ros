<?xml version="1.0"?>
<model>
  <name>Unitree G1 29DoF free-base joint position control</name>
  <version>1.0</version>
  <sdf version="1.11">model.sdf</sdf>
  <author>
    <name>Local Gazebo Harmonic ROS 2 workspace</name>
  </author>
  <description>
    Gazebo Harmonic SDF variant generated from Unitree g1_29dof_rev_1_0.urdf.
    This free-base variant preserves the original URDF inertials for the
    floating body and all fixed child links while exposing low-level Gazebo
    joint position controllers and joint-state publishing for ros_gz_bridge.
  </description>
</model>
