# Gazebo runtime state mounted from the container.
# Keep reproducible models/worlds in workspace/models and workspace/worlds.
gazebo_config/*
!gazebo_config/.gitkeep

# Downloaded Fuel assets and signed URLs can appear in logs/cache.
**/fuel/
**/sim/log/
**/rendering/

